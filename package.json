{
  "name": "hoopcoach",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack AI basketball training assistant.",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run dev --workspace frontend\"",
    "backend:dev": "cd backend && .venv/bin/python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 4010",
    "mobile:dev": "npm run start --workspace mobile",
    "build": "npm run build --workspace frontend",
    "typecheck": "npm run typecheck --workspace frontend && npm run typecheck --workspace mobile"
  },
  "workspaces": [
    "frontend",
    "mobile"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
